# File: .env.example
# Copy this file to .env and fill in the values.
# Coolify can also inject these as environment variables directly.

# ----------------------------------------------------------------------------
# GitHub App authentication
# ----------------------------------------------------------------------------
# Numeric GitHub App ID
GITHUB_APP_ID=1234567

# Numeric installation ID for the app installation in your org/account
GITHUB_APP_INSTALLATION_ID=12345678

# Absolute path to the GitHub App PEM file on the Docker host.
# docker-compose.yml bind-mounts this into every runner container at
# /run/secrets/github_app_key (read-only). The key file contents are not
# exposed to the container environment, but the host path is visible in
# `docker inspect` output under Mounts[].
# Example: /etc/github-app/private-key.pem
GITHUB_APP_PRIVATE_KEY_HOST_PATH=

# Optional for GitHub Enterprise Server. Set these explicitly for your instance.
# Leave the defaults below for GitHub Cloud.
# Note: GITHUB_HOST is informational only; the scripts use GITHUB_API_URL and
# GITHUB_WEB_URL directly. For GHES, update those two values accordingly.
GITHUB_HOST=github.com
GITHUB_API_URL=https://api.github.com
GITHUB_WEB_URL=https://github.com

# ----------------------------------------------------------------------------
# Runner scope
# ----------------------------------------------------------------------------
# org or repo
RUNNER_SCOPE=org

# Required when RUNNER_SCOPE=org
GITHUB_ORG=your-org

# Required when RUNNER_SCOPE=repo
GITHUB_REPO_OWNER=your-org
GITHUB_REPO_NAME=your-repo

# Optional runner group for org-scoped runners
RUNNER_GROUP=Default

# ----------------------------------------------------------------------------
# Shared defaults
# ----------------------------------------------------------------------------
RUNNER_IMAGE_NAME=local/github-app-actions-runner:latest
RUNNER_CONTAINER_PREFIX=gha-runner
RUNNER_DEFAULT_LABELS=self-hosted,linux,x64,docker,ephemeral
RUNNER_WORKDIR=/home/runner/_work
# UID of the runner user inside the container.  Used as the tmpfs owner for
# /runner-tmp so that the directory has mode 0700 and is inaccessible to
# other UIDs.
# Verify with: docker run --rm ghcr.io/actions/actions-runner:2.333.1 id runner
RUNNER_UID=1001
# When true (the default), entrypoint.sh unsets configuration variables that are
# no longer needed after runner registration so they do not leak into job
# subprocesses.  Set to false only for debugging.
UNSET_CONFIG_VARS=true

# Per-runner resource limits. Tune to host capacity; defaults are
# conservative and prevent one runaway workflow from DoS-ing siblings.
RUNNER_MEM_LIMIT=4g
RUNNER_CPUS=2
RUNNER_PIDS_LIMIT=1024

# ----------------------------------------------------------------------------
# Runner instances
# Each runner service in docker-compose.yml passes RUNNER_DEFAULT_LABELS and
# RUNNER_EXTRA_LABELS (mapped from RUNNER_N_LABELS below) to the container.
# entrypoint.sh assembles the final label set: if RUNNER_EXTRA_LABELS is
# non-empty it becomes "<RUNNER_DEFAULT_LABELS>,<RUNNER_EXTRA_LABELS>",
# otherwise only RUNNER_DEFAULT_LABELS is used (no trailing comma).
# Extend by adding another service in docker-compose.yml and another label line.
# ----------------------------------------------------------------------------
RUNNER_1_LABELS=lint,small
RUNNER_2_LABELS=lint,medium
RUNNER_3_LABELS=general

# Optional: set explicit names. Empty means prefix + hostname/random suffix.
RUNNER_1_NAME=
RUNNER_2_NAME=
RUNNER_3_NAME=
